{
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" },
    { "src": "public/*.html", "use": "@vercel/static" },
    { "src": "public/*.css", "use": "@vercel/static" },
    { "src": "public/*.js", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.py" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}